---
import DossierCard from '../components/DossierCard.astro';
import PageHero from '../components/PageHero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import WorkshopCard from '../components/WorkshopCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { dossiers } from '../data/dossiers';
import { heroContent } from '../data/page-heroes';
import {
	AUDIENCE_SEGMENTS,
	COMMUNITY_PARTNERS,
	INQUIRY_PATHS,
	ECOSYSTEM_PILLARS,
	SITE_CONTACT,
	TRUST_POINTS,
} from '../data/site';
import { services } from '../data/services';
import { workshops } from '../data/workshops';
import MainLayout from '../layouts/MainLayout.astro';

const homeHeroSlides = [
	heroContent.home,
	heroContent.services,
	heroContent.workshops,
	heroContent.projects,
];
---

<MainLayout
	title={SITE_TITLE}
	description={SITE_DESCRIPTION}
	image="/images/banners/banner-2.png"
>
	<PageHero
		eyebrow={heroContent.home.eyebrow}
		title={heroContent.home.title}
		description={heroContent.home.description}
		image={heroContent.home.image}
		imageAlt={heroContent.home.imageAlt}
		actions={heroContent.home.actions}
		carouselId="homeHeroCarousel"
		autoplay={false}
		slides={homeHeroSlides}
	/>

	<section class="page-section page-section--wash-blue page-section--symbol-air">
		<div class="container">
			<div class="section-heading">
				<p class="eyebrow">Rutas de consulta</p>
				<h2>Entradas claras para empresas, colegios, municipios y eventos privados</h2>
				<p>
					La propuesta principal ya esta definida desde el primer pliegue. Aqui dejamos caminos directos
					para que cada contraparte llegue rapido a la conversacion correcta.
				</p>
			</div>
			<div class="path-grid">
				{INQUIRY_PATHS.map((path) => (
					<article class="path-card">
						<h3>{path.title}</h3>
						<p>{path.summary}</p>
						<a
							class="site-link"
							href={path.href}
							target={path.target}
							rel={path.target === '_blank' ? 'noopener noreferrer' : undefined}
						>
							{path.label}
						</a>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="page-section page-section--symbol-water">
		<div class="container">
			<div class="section-heading">
				<p class="eyebrow">Que hacemos</p>
				<h2>Un ecosistema que cruza bienestar, escena y trabajo con personas</h2>
			</div>
			<div class="icon-card-grid">
				{ECOSYSTEM_PILLARS.map((pillar) => (
					<article class="icon-card">
						<h3>{pillar.title}</h3>
						<p>{pillar.description}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="page-section page-section--wash-gold page-section--symbol-fire">
		<div class="container">
			<div class="section-heading">
				<p class="eyebrow">Servicios principales</p>
				<h2>Rutas claras para contratar, colaborar o activar una experiencia</h2>
				<p>
					La oferta principal del sitio esta orientada a instituciones, equipos, espacios culturales,
					organizaciones y clientes privados que necesitan una propuesta seria, viva y bien ejecutada.
				</p>
			</div>
			<div class="content-grid">
				{services.map((service) => (
					<ServiceCard service={service} />
				))}
			</div>
		</div>
	</section>

	<section class="page-section page-section--wash-blue page-section--symbol-water">
		<div class="container split-panel">
			<div>
				<p class="eyebrow">Para quien trabajamos</p>
				<h2>Distintos contextos, una misma forma de trabajar</h2>
				<p>
					No somos solo un espacio de talleres. La propuesta tambien conversa con necesidades
					institucionales, celebraciones, jornadas de bienestar, eventos y acciones territoriales.
				</p>
				<ul class="pill-list">
					{AUDIENCE_SEGMENTS.map((audience) => (
						<li>{audience}</li>
					))}
				</ul>
			</div>
			<div class="trust-panel">
				<h3>Por que confiar</h3>
				<ul class="check-list">
					{TRUST_POINTS.map((point) => (
						<li>{point}</li>
					))}
				</ul>
			</div>
		</div>
	</section>

	<section class="page-section page-section--wash-green page-section--symbol-earth">
		<div class="container">
			<div class="section-heading">
				<p class="eyebrow">Talleres regulares</p>
				<h2>La practica constante sigue siendo parte del corazon de Elementos</h2>
				<p>
					Los talleres viven dentro del ecosistema, pero ya no cargan solos con todo el relato del sitio.
					Aqui aparecen como una linea activa, concreta y accesible.
				</p>
			</div>
			<div class="workshop-grid">
				{workshops.slice(0, 4).map((workshop) => (
					<WorkshopCard workshop={workshop} />
				))}
			</div>
			<div class="section-actions">
				<a class="site-button" href="/talleres">Conoce los talleres</a>
			</div>
		</div>
	</section>

	<section class="page-section page-section--wash-green page-section--symbol-air">
		<div class="container split-panel split-panel--media">
			<div>
				<p class="eyebrow">Proyectos comunitarios</p>
				<h2>Trabajo territorial, colaboraciones y acciones con comunidad</h2>
				<p>
					La dimension comunitaria valida la trayectoria del proyecto y muestra que la cercania no es un
					discurso, sino una forma real de relacionarse con el territorio, los equipos y las personas.
				</p>
				<a class="site-link" href="/proyectos">Ver proyectos comunitarios</a>
			</div>
			<div class="logo-cloud">
				{COMMUNITY_PARTNERS.map((partner) => (
					<a href={partner.href} target="_blank" rel="noopener noreferrer" aria-label={partner.name}>
						<img src={partner.logo} alt={partner.name} />
					</a>
				))}
			</div>
		</div>
	</section>

	<section class="page-section page-section--wash-orange page-section--symbol-fire">
		<div class="container">
			<div class="section-heading">
				<p class="eyebrow">Dossiers</p>
				<h2>Material comercial disponible para conversaciones y cotizaciones</h2>
				<p>
					El sitio ya puede compartir material institucional y comercial para conversaciones, cotizaciones
					y presentaciones de proyecto.
				</p>
			</div>
			<div class="dossier-grid">
				{dossiers.slice(0, 2).map((dossier) => (
					<DossierCard dossier={dossier} />
				))}
			</div>
		</div>
	</section>

	<section class="page-section page-section--contact">
		<div class="container contact-banner">
			<div>
				<p class="eyebrow">Contacto</p>
				<h2>Conversemos tu evento, proyecto o necesidad institucional</h2>
				<p>
					Si quieres cotizar una experiencia, solicitar un dossier o consultar por talleres, te respondemos
					por correo o WhatsApp.
				</p>
			</div>
			<div class="contact-banner__actions">
				<a class="site-button" href="/contacto">Ir a contacto</a>
				<a class="site-button site-button--secondary" href={SITE_CONTACT.emailHref}>Escribir por correo</a>
			</div>
		</div>
	</section>
</MainLayout>
