    <!-- ────────────────────────────────────────────
         NACE SOCIAL DE RENGO
         ──────────────────────────────────────────── -->
    <section class="lrs-section lrs-nace-section" aria-labelledby="nace-heading">
      <div class="lrs-nace-bg" aria-hidden="true">
        <div class="lrs-nace-glow lrs-nace-glow--left"></div>
        <div class="lrs-nace-glow lrs-nace-glow--right"></div>
      </div>
      <div class="lrs-container lrs-container--narrow">
        <span class="lrs-eyebrow">Latin Rengo</span>
        <h2 class="lrs-nace__title" id="nace-heading">
          Nace el<br>
          <em class="lrs-neon-blue">Social de Rengo</em>
        </h2>
        <p class="lrs-nace__text">
          Este no es solo un evento de aniversario. Es el comienzo de algo que Rengo no tenía: un espacio propio para la salsa y la bachata.
        </p>
        <p class="lrs-nace__text">
          Latin Rengo cumple un año construyendo comunidad en la región. El <span class="lrs-social-word">Social</span> de Rengo nace para ser un punto de encuentro mensual, donde la gente pueda bailar, conocerse y crecer junto a la música latina.
        </p>
        <p class="lrs-nace__text lrs-nace__text--accent">
          Si vienes, eres parte del comienzo.
        </p>
      </div>
    </section>

    <!-- ────────────────────────────────────────────
         FAQ
         ──────────────────────────────────────────── -->
    <section class="lrs-section lrs-section--dark lrs-faq-section" id="preguntas" aria-labelledby="faq-heading">
      <div class="lrs-container lrs-container--narrow">
        <div class="lrs-section-header">
          <span class="lrs-eyebrow">Dudas frecuentes</span>
          <h2 class="lrs-heading" id="faq-heading">Preguntas frecuentes</h2>
        </div>

        <div class="lrs-faq">
          {FAQS.map((item) => (
            <details class="lrs-faq__item">
              <summary class="lrs-faq__question">
                <span>
                  {splitSocialWords(item.q).map((part) => (
                    SOCIAL_WORD_RE.test(part) ? <span class="lrs-social-word">{part}</span> : part
                  ))}
                </span>
                <span class="lrs-faq__icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </summary>
              <p class="lrs-faq__answer">
                {splitSocialWords(item.a).map((part) => (
                  SOCIAL_WORD_RE.test(part) ? <span class="lrs-social-word">{part}</span> : part
                ))}
              </p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ────────────────────────────────────────────
         CTA FINAL
         ──────────────────────────────────────────── -->
