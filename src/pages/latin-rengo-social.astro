---
import BaseHead from '../components/BaseHead.astro';

const PAGE_TITLE = "Social de Rengo — El 1er Social de Salsa y Bachata | Latin Rengo";
const PAGE_DESC  = "El primer social de salsa y bachata de Rengo. Sábado 18 de julio, de 21:00 a 03:00 hrs, organizado por Latin Rengo. No necesitas pareja ni experiencia.";
const PAGE_IMAGE = "/images/og/latin-rengo-social-og.jpg";

const WA_NUM    = "56979898502";
const WA_TICKET = `https://wa.me/${WA_NUM}?text=${encodeURIComponent("Hola! Quiero reservar mi entrada para el Social de Rengo 🎶")}`;
const MAP_QUERY = "Centro de Eventos Mariette, Rengo, Chile";
const MAP_EMBED = `https://maps.google.com/maps?hl=es&q=${encodeURIComponent(MAP_QUERY)}&z=16&output=embed`;
const MAP_LINK  = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(MAP_QUERY)}`;
const CALENDAR_LINK = "https://calendar.google.com/calendar/render?action=TEMPLATE"
  + `&text=${encodeURIComponent("Latin Rengo Social")}`
  + "&dates=20260718T210000/20260719T030000"
  + "&ctz=America/Santiago"
  + `&details=${encodeURIComponent("El 1er Social de Salsa y Bachata de Rengo. Clase inicial, shows invitados y pista abierta.")}`
  + `&location=${encodeURIComponent(MAP_QUERY)}`;
const LATIN_RENGO_CONTACT = "+56 9 7989 8502";
const LATIN_RENGO_INSTAGRAM = "https://instagram.com/latin.rengo";
const currentYear = new Date().getFullYear();
const SOCIAL_WORD_RE = /^(Sociales|Social|sociales|social)$/;
const splitSocialWords = (value: string) => value.split(/(Sociales|Social|sociales|social)/g);

const TICKETS = [
  {
    slug:      "preventa",
    name:      "Preventa",
    price:     "$3.000",
    note:      "Disponible hasta agotar",
    items:     ["Acceso al social", "Clase de salsa cubana incluida"],
    available: true,
    badge:     "Mejor precio",
    color:     "orange",
    featured:  false,
  },
  {
    slug:      "general",
    name:      "General",
    price:     "$5.000",
    note:      "Compra con anticipación",
    items:     ["Acceso al social", "Clase de salsa cubana incluida"],
    available: true,
    badge:     null,
    color:     "blue",
    featured:  true,
  },
  {
    slug:      "puerta",
    name:      "En Puerta",
    price:     "$8.000",
    note:      "Sujeto a disponibilidad",
    items:     ["Acceso al social", "Clase de salsa cubana incluida"],
    available: true,
    badge:     null,
    color:     "dim",
    featured:  false,
  },
];

const SCHEDULE = [
  { time: "21:00",        title: "Clase de Salsa Cubana",    desc: "Clase especial para todos los niveles. Sin experiencia previa necesaria.", marked: false, social: false },
  { time: "22:00",        title: "Inicio del Social",        desc: "Pista abierta. Baila con quien quieras al ritmo de salsa y bachata.",      marked: true,  social: false },
  { time: "23:00",        title: "Shows Invitados",           desc: "Academias y artistas invitados toman la pista.",                          marked: false, social: false },
  { time: "Desde 00:00",  title: "Social de Salsa y Bachata", desc: "La noche continúa. Baila hasta el final.",                               marked: false, social: true  },
];

const WHY = [
  { icon: "👤", text: "No necesitas pareja" },
  { icon: "🎓", text: "No necesitas experiencia" },
  { icon: "👥", text: "Conocerás personas nuevas" },
  { icon: "💃", text: "Clase incluida en la entrada" },
  { icon: "⭐", text: "Shows invitados en vivo" },
  { icon: "🍻", text: "Barra y comida disponible" },
  { icon: "🎶", text: "Salsa y bachata toda la noche" },
];

const PERFORMERS = [
  {
    artist: "Artista invitado",
    show: "Nombre de la coreografía o show",
    desc: "Aquí irá una breve descripción de quiénes son, qué presentan y por qué son parte de esta primera noche.",
    link: "Sitio, Instagram o video por confirmar",
    color: "blue",
  },
  {
    artist: "Academia o grupo invitado",
    show: "Show por confirmar",
    desc: "Esta tarjeta queda preparada para presentar a academias, grupos o bailarines que se sumen a la celebración.",
    link: "Enlace por confirmar",
    color: "orange",
  },
  {
    artist: "Bailarines invitados",
    show: "Presentación por confirmar",
    desc: "La idea es mostrar cada participación como parte de una comunidad que crece alrededor de la salsa y la bachata.",
    link: "Video o red social por confirmar",
    color: "purple",
  },
];

const FAQS = [
  {
    q: "¿Es necesario saber bailar?",
    a: "No hace falta. La noche parte con una clase de salsa cubana para soltar el cuerpo, aprender pasos básicos y entrar en confianza antes de que se abra la pista.",
  },
  {
    q: "¿Necesito ir con pareja?",
    a: "No. Puedes llegar solo, sola, con amistades o en pareja. En un social lo normal es compartir baile con distintas personas, siempre con respeto y buena onda.",
  },
  {
    q: "¿Cómo compro mi entrada?",
    a: "Escríbenos por WhatsApp y te ayudamos con la reserva. Es la forma más simple de asegurar tu entrada y recibir la información práctica del evento.",
  },
  {
    q: "¿Dónde queda el lugar?",
    a: "Será en Centro de Eventos Mariette, en Rengo. Dejamos el mapa en esta página y, al reservar, te enviamos la referencia exacta para que llegues sin perderte.",
  },
  {
    q: "¿Habrá barra y comida?",
    a: "Sí. La idea es que puedas bailar, descansar un rato, compartir algo y volver a la pista cuando quieras.",
  },
  {
    q: "¿Habrá más Sociales después de este?",
    a: "Eso queremos. Este primer encuentro es el punto de partida para que Rengo tenga un espacio propio de salsa, bachata y comunidad.",
  },
  {
    q: "¿Puedo ir si me da vergüenza bailar?",
    a: "Sí, y probablemente no serás la única persona. Puedes mirar, tomar la clase, bailar cuando te nazca o simplemente acompañar. La noche está pensada para pasarlo bien, no para evaluarte.",
  },
  {
    q: "¿Qué música habrá?",
    a: "Salsa, bachata y más música latina para mantener la pista viva durante la noche.",
  },
];
---

<!doctype html>
<html lang="es">
<head>
  <BaseHead title={PAGE_TITLE} description={PAGE_DESC} image={PAGE_IMAGE} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Lobster&family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet">
</head>

<body class="page page--latin-rengo-social">

  <header class="lrs-page-header" aria-label="Navegación de Latin Rengo Social">
    <div class="lrs-container lrs-page-header__inner">
      <a class="lrs-page-header__brand" href="#lrs-top" aria-label="Volver al inicio de Latin Rengo Social">
        <span class="lrs-page-header__brand-mark-wrap" aria-hidden="true">
          <img class="lrs-page-header__brand-mark" src="/images/colaboradores/isotipo-latinrengo.png" alt="" width="152" height="152" />
        </span>
        <span class="lrs-page-header__brand-text" aria-label="Latin Rengo">
          <span class="lrs-page-header__brand-word lrs-page-header__brand-word--latin">Latin</span>
          <span class="lrs-page-header__brand-word lrs-page-header__brand-word--rengo">Rengo</span>
        </span>
        <span class="lrs-page-header__brand-social lrs-social-word">Social</span>
      </a>
      <nav class="lrs-page-header__nav" aria-label="Secciones de la landing">
        <a href="#social">¿Qué es?</a>
        <a href="#asistir">Por qué ir</a>
        <a href="#entradas">Entradas</a>
        <a href="#programa">Programa</a>
        <a href="#shows">Shows</a>
        <a href="#ubicacion">Cómo llegar</a>
        <a href="#preguntas">Preguntas</a>
      </nav>
      <a class="lrs-page-header__cta" href={WA_TICKET} target="_blank" rel="noopener noreferrer">
        Reservar
      </a>
    </div>
  </header>

  <main class="site-main lrs-main" id="lrs-top">

    <!-- ────────────────────────────────────────────
         HERO
         ──────────────────────────────────────────── -->
    <section class="lrs-hero" aria-label="Social de Rengo — El primer social de salsa y bachata">
      <div class="lrs-hero__bg" aria-hidden="true">
        <div class="lrs-hero__glow lrs-hero__glow--orange"></div>
        <div class="lrs-hero__glow lrs-hero__glow--purple"></div>
        <div class="lrs-hero__glow lrs-hero__glow--blue"></div>
      </div>

      <div class="lrs-container">
        <div class="lrs-hero__inner">

          <div class="lrs-hero__content">
            <p class="lrs-hero__organizer">Latin Rengo · Primer Aniversario</p>

            <h1 class="lrs-hero__title">
              <span class="lrs-hero__title-line lrs-hero__title-line--sm">El</span>
              <span class="lrs-hero__title-line lrs-hero__title-line--mega lrs-neon-blue">1er Social</span>
              <span class="lrs-hero__title-line lrs-hero__title-line--md">de Salsa y Bachata</span>
              <span class="lrs-hero__title-line lrs-hero__title-line--sm">en Rengo</span>
            </h1>

            <p class="lrs-hero__tagline">
              Celebrando el primer aniversario de Latin Rengo.
            </p>
          </div>

          <div class="lrs-hero__poster" aria-hidden="true">
            <div class="lrs-hero__poster-frame">
              <img
                src="/images/latin-rengo-social-poster.jpg"
                alt="Afiche oficial de Latin Rengo Social"
                width="1080"
                height="1350"
                loading="eager"
                fetchpriority="high"
              />
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ────────────────────────────────────────────
         DATOS CLAVE / ACCIONES
         ──────────────────────────────────────────── -->
    <section class="lrs-event-strip" aria-label="Datos principales y acciones del evento">
      <div class="lrs-container">
        <div class="lrs-event-strip__grid">
          <a class="lrs-event-card lrs-event-card--orange" href={CALENDAR_LINK} target="_blank" rel="noopener noreferrer" aria-label="Agregar Latin Rengo Social a Google Calendar">
            <span class="lrs-event-card__icon" aria-hidden="true">📅</span>
            <span class="lrs-event-card__label">Fecha</span>
            <strong>Sábado 18 de julio</strong>
          </a>
          <div class="lrs-event-card lrs-event-card--purple">
            <span class="lrs-event-card__icon" aria-hidden="true">🕘</span>
            <span class="lrs-event-card__label">Hora</span>
            <strong>21:00 – 03:00 hrs</strong>
          </div>
          <a class="lrs-event-card lrs-event-card--purple" href="#ubicacion">
            <span class="lrs-event-card__icon" aria-hidden="true">📍</span>
            <span class="lrs-event-card__label">Lugar</span>
            <strong>Rengo</strong>
          </a>
          <a class="lrs-event-card lrs-event-card--green" href={WA_TICKET} target="_blank" rel="noopener noreferrer">
            <span class="lrs-event-card__icon" aria-hidden="true">💬</span>
            <span class="lrs-event-card__label">Entrada</span>
            <strong>Reserva por WhatsApp</strong>
          </a>
          <a class="lrs-event-card lrs-event-card--orange" href="#programa">
            <span class="lrs-event-card__icon" aria-hidden="true">🎵</span>
            <span class="lrs-event-card__label">Programa</span>
            <strong>Ver la noche</strong>
          </a>
        </div>
      </div>
    </section>

    <!-- ────────────────────────────────────────────
         ¿QUÉ ES UN SOCIAL?
         ──────────────────────────────────────────── -->
    <section class="lrs-section lrs-section--dark lrs-social-section" id="social" aria-labelledby="que-es-heading">
      <div class="lrs-container lrs-container--narrow">
        <div class="lrs-section-header">
          <span class="lrs-eyebrow">Antes de llegar</span>
          <h2 class="lrs-heading" id="que-es-heading">¿Qué es un <span class="lrs-social-word">Social</span>?</h2>
        </div>
        <div class="lrs-explainer">
          <p class="lrs-explainer__text">
            Un <strong class="lrs-social-word">Social</strong> es una noche para encontrarse, escuchar buena música y bailar sin presión. Puedes venir a mirar, conversar, tomar la clase o lanzarte a la pista cuando te sientas listo.
          </p>
          <p class="lrs-explainer__text">
            No necesitas pareja, experiencia ni pasos perfectos. La idea es que la comunidad te reciba, que pruebes algo nuevo y que lo pases bien con personas que también quieren aprender y compartir.
          </p>
          <p class="lrs-explainer__text">
            Si es tu primera vez, mejor todavía. Llegas a la clase de las 21:00, aprendes pasos básicos, entras en ambiente y después decides cuánto quieres bailar.
          </p>
        </div>
      </div>
    </section>

    <!-- ────────────────────────────────────────────
         ¿POR QUÉ ASISTIR?
         ──────────────────────────────────────────── -->
    <section class="lrs-section lrs-section--darkest lrs-why-section" id="asistir" aria-labelledby="por-que-heading">
      <div class="lrs-container">
        <div class="lrs-section-header">
          <span class="lrs-eyebrow">Razones para ir</span>
          <h2 class="lrs-heading" id="por-que-heading">¿Por qué asistir?</h2>
        </div>
        <ul class="lrs-why" aria-label="Razones para asistir al Social de Rengo">
          {WHY.map((item) => (
            <li class="lrs-why__item">
              <span class="lrs-why__icon" aria-hidden="true">{item.icon}</span>
              <span class="lrs-why__text">{item.text}</span>
            </li>
          ))}
        </ul>
        <div class="lrs-why__cta">
          <a class="lrs-btn lrs-btn--primary" href={WA_TICKET} target="_blank" rel="noopener noreferrer">
            Reservar entrada ahora
          </a>
        </div>
      </div>
    </section>

    <!-- ────────────────────────────────────────────
         ENTRADAS
         ──────────────────────────────────────────── -->
    <section class="lrs-section lrs-section--dark" id="entradas" aria-labelledby="entradas-heading">
      <div class="lrs-container">
        <div class="lrs-section-header">
          <span class="lrs-eyebrow">Entradas</span>
          <h2 class="lrs-heading" id="entradas-heading">Elige tu entrada</h2>
          <p class="lrs-lead">La preventa tiene cupo limitado. Reserva por WhatsApp para asegurar el mejor precio.</p>
        </div>

        <ul class="lrs-tickets">
          {TICKETS.map((t) => (
            <li class:list={["lrs-ticket", t.featured && "lrs-ticket--featured", `lrs-ticket--${t.color}`]}>
              {t.badge && (
                <span class:list={["lrs-ticket__badge", `lrs-ticket__badge--${t.color}`]}>
                  {t.badge}
                </span>
              )}
              <h3 class="lrs-ticket__name">{t.name}</h3>
              <div class="lrs-ticket__price">{t.price}</div>
              <p class="lrs-ticket__note">{t.note}</p>
              <ul class="lrs-ticket__items">
                {t.items.map((item) => (
                  <li class="lrs-ticket__item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                    {splitSocialWords(item).map((part) => (
                      SOCIAL_WORD_RE.test(part) ? <span class="lrs-social-word">{part}</span> : part
                    ))}
                  </li>
                ))}
              </ul>
              <a class="lrs-btn lrs-btn--ticket" href={WA_TICKET} target="_blank" rel="noopener noreferrer">
                Reservar por WhatsApp
              </a>
            </li>
          ))}
        </ul>

        <p class="lrs-footnote lrs-footnote--center">Las entradas se reservan por WhatsApp. Cupo limitado.</p>
      </div>
    </section>

    <!-- ────────────────────────────────────────────
         CRONOGRAMA
         ──────────────────────────────────────────── -->
    <section class="lrs-section lrs-section--darkest lrs-program-section" id="programa" aria-labelledby="cronograma-heading">
      <div class="lrs-container lrs-container--narrow">
        <div class="lrs-section-header">
          <span class="lrs-eyebrow">La noche</span>
          <h2 class="lrs-heading" id="cronograma-heading">Cronograma</h2>
        </div>

        <ol class="lrs-timeline" aria-label="Programa de la noche">
          {SCHEDULE.map((item) => (
            <li class:list={["lrs-timeline__item", item.marked && "lrs-timeline__item--marked", item.social && "lrs-timeline__item--social"]}>
              <div class="lrs-timeline__time">{item.time}</div>
              <div class="lrs-timeline__body">
                <h3 class="lrs-timeline__title">
                  {splitSocialWords(item.title).map((part) => (
                    SOCIAL_WORD_RE.test(part) ? <span class="lrs-social-word">{part}</span> : part
                  ))}
                </h3>
                {item.desc && <p class="lrs-timeline__desc">{item.desc}</p>}
              </div>
            </li>
          ))}
        </ol>

        <p class="lrs-footnote lrs-footnote--center">* Horarios referenciales, sujetos a cambios.</p>
      </div>
    </section>

    <!-- ────────────────────────────────────────────
         GALERÍA
         ──────────────────────────────────────────── -->
    <section class="lrs-section lrs-section--dark lrs-gallery-section" id="latin-rengo" aria-labelledby="galeria-heading">
      <div class="lrs-container">
        <div class="lrs-section-header">
          <span class="lrs-eyebrow">Comunidad</span>
          <h2 class="lrs-heading" id="galeria-heading">Así es Latin Rengo</h2>
          <p class="lrs-lead">Clases, <span class="lrs-social-word">sociales</span> y comunidad de salsa y bachata en Rengo.</p>
        </div>

        <div class="lrs-gallery" aria-label="Fotografías de clases y eventos de Latin Rengo">
          <div class="lrs-gallery__item lrs-gallery__item--tall">
            <div class="lrs-gallery__ph">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              <span>Clases de Latin Rengo</span>
            </div>
          </div>
          <div class="lrs-gallery__item">
            <div class="lrs-gallery__ph">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              <span>Baile <span class="lrs-social-word">social</span></span>
            </div>
          </div>
          <div class="lrs-gallery__item">
            <div class="lrs-gallery__ph">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              <span>Comunidad</span>
            </div>
          </div>
          <div class="lrs-gallery__item lrs-gallery__item--wide">
            <div class="lrs-gallery__ph">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              <span>Eventos anteriores</span>
            </div>
          </div>
          <div class="lrs-gallery__item">
            <div class="lrs-gallery__ph">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              <span>Presentaciones</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ────────────────────────────────────────────
         SHOWS / PRESENTACIONES
         ──────────────────────────────────────────── -->
    <section class="lrs-section lrs-section--darkest lrs-shows-section" id="shows" aria-labelledby="shows-heading">
      <div class="lrs-container">
        <div class="lrs-section-header">
          <span class="lrs-eyebrow">En escena</span>
          <h2 class="lrs-heading" id="shows-heading">Shows de la noche</h2>
          <p class="lrs-lead">Los shows y academias invitados se confirmarán próximamente. Sigue a Latin Rengo en redes para saberlo primero.</p>
        </div>

        <div class="lrs-performers">
          {PERFORMERS.map((p) => (
            <div class:list={["lrs-performer", `lrs-performer--${p.color}`]}>
              <div class="lrs-performer__ring" aria-hidden="true">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </div>
              <details class="lrs-performer__details">
                <summary>
                  <span class="lrs-performer__name">{p.artist}</span>
                  <span class="lrs-performer__role">{p.show}</span>
                </summary>
                <p class="lrs-performer__desc">{p.desc}</p>
                <p class="lrs-performer__link">{p.link}</p>
              </details>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ────────────────────────────────────────────
         CÓMO LLEGAR
         ──────────────────────────────────────────── -->
    <section class="lrs-section lrs-section--dark lrs-location-section" id="ubicacion" aria-labelledby="ubicacion-heading">
      <div class="lrs-container">
        <div class="lrs-location">
          <div class="lrs-location__content">
            <span class="lrs-eyebrow">Cómo llegar</span>
            <h2 class="lrs-heading" id="ubicacion-heading">Centro de Eventos Mariette</h2>
            <p class="lrs-lead lrs-location__lead">
              El <span class="lrs-social-word">Social</span> de Rengo será en Centro de Eventos Mariette, en Rengo.
            </p>

            <dl class="lrs-location__details">
              <div>
                <dt>Lugar</dt>
                <dd>Centro de Eventos Mariette</dd>
              </div>
              <div>
                <dt>Ciudad</dt>
                <dd>Rengo</dd>
              </div>
              <div>
                <dt>Dirección exacta</dt>
                <dd>Se entregará al reservar tu entrada por WhatsApp.</dd>
              </div>
            </dl>

