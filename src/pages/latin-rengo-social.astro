---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const PAGE_TITLE = "Social de Rengo — El 1er Social de Salsa y Bachata | Latin Rengo";
const PAGE_DESC  = "El primer social de salsa y bachata de Rengo. Una noche histórica organizada por Latin Rengo, celebrando su primer aniversario. No necesitas pareja ni experiencia.";
const PAGE_IMAGE = "/images/og/latin-rengo-social-og.jpg";

const WA_NUM    = "56956490299";
const WA_TICKET = `https://wa.me/${WA_NUM}?text=${encodeURIComponent("Hola! Quiero reservar mi entrada para el Social de Rengo 🎶")}`;

const TICKETS = [
  {
    slug:      "preventa",
    name:      "Preventa",
    price:     "$3.000",
    note:      "Disponible hasta agotar",
    items:     ["Acceso al social", "Clase de salsa cubana incluida"],
    available: true,
    badge:     "Mejor precio",
    color:     "orange",
    featured:  false,
  },
  {
    slug:      "general",
    name:      "General",
    price:     "$5.000",
    note:      "Compra con anticipación",
    items:     ["Acceso al social", "Clase de salsa cubana incluida"],
    available: true,
    badge:     null,
    color:     "blue",
    featured:  true,
  },
  {
    slug:      "puerta",
    name:      "En Puerta",
    price:     "$8.000",
    note:      "Sujeto a disponibilidad",
    items:     ["Acceso al social", "Clase de salsa cubana incluida"],
    available: true,
    badge:     null,
    color:     "dim",
    featured:  false,
  },
];

const SCHEDULE = [
  { time: "21:00",        title: "Clase de Salsa Cubana",    desc: "Clase especial para todos los niveles. Sin experiencia previa necesaria.", marked: false },
  { time: "22:00",        title: "Inicio del Social",        desc: "Pista abierta. Baila con quien quieras al ritmo de salsa y bachata.",      marked: true  },
  { time: "23:00",        title: "Shows Invitados",           desc: "Academias y artistas invitados toman la pista.",                          marked: false },
  { time: "00:00–03:00",  title: "Social de Salsa y Bachata", desc: "La noche continúa. Baila hasta el final.",                               marked: false },
];

const WHY = [
  { icon: "👤", text: "No necesitas pareja" },
  { icon: "🎓", text: "No necesitas experiencia" },
  { icon: "👥", text: "Conocerás personas nuevas" },
  { icon: "💃", text: "Clase incluida en la entrada" },
  { icon: "⭐", text: "Shows invitados en vivo" },
  { icon: "🍻", text: "Barra y comida disponible" },
  { icon: "🎶", text: "Salsa y bachata toda la noche" },
];

const PERFORMERS = [
  { label: "Academias Invitadas",         role: "Escuelas de baile de la región",   color: "blue"   },
  { label: "Shows Confirmados Pronto",    role: "Artistas locales y regionales",     color: "orange" },
  { label: "Artistas Invitados",          role: "Por confirmar próximamente",        color: "purple" },
];

const FAQS = [
  {
    q: "¿Es necesario saber bailar?",
    a: "No. Hay una clase de salsa cubana a las 21:00 para quienes quieran aprender los básicos. El social está abierto a todos los niveles.",
  },
  {
    q: "¿Necesito ir con pareja?",
    a: "Para nada. Un social funciona exactamente al revés: llegas solo o sola, bailas con distintas personas durante la noche. Es parte de la magia.",
  },
  {
    q: "¿Cómo compro mi entrada?",
    a: "Reserva directamente por WhatsApp. También habrá entradas disponibles en puerta el mismo día, según disponibilidad.",
  },
  {
    q: "¿Dónde queda el lugar?",
    a: "El lugar se confirmará próximamente. Sigue a Latin Rengo en redes o escríbenos por WhatsApp para ser el primero en saberlo.",
  },
  {
    q: "¿Habrá barra y comida?",
    a: "Sí, el evento contará con barra y opciones de comida en el lugar.",
  },
  {
    q: "¿Habrá más Sociales después de este?",
    a: "Este es el primero y queremos que sea el comienzo de algo grande para Rengo. Si la comunidad responde, el Social de Rengo seguirá creciendo.",
  },
];
---

<!doctype html>
<html lang="es">
<head>
  <BaseHead title={PAGE_TITLE} description={PAGE_DESC} image={PAGE_IMAGE} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet">
</head>

<body class="page page--latin-rengo-social">

  <Header />

  <main class="site-main lrs-main" id="lrs-top">

    <!-- ────────────────────────────────────────────
         HERO
         ──────────────────────────────────────────── -->
    <section class="lrs-hero" aria-label="Social de Rengo — El primer social de salsa y bachata">
      <div class="lrs-hero__bg" aria-hidden="true">
        <div class="lrs-hero__glow lrs-hero__glow--orange"></div>
        <div class="lrs-hero__glow lrs-hero__glow--purple"></div>
        <div class="lrs-hero__glow lrs-hero__glow--blue"></div>
      </div>

      <div class="lrs-container">
        <div class="lrs-hero__inner">

          <div class="lrs-hero__content">
            <p class="lrs-hero__organizer">Latin Rengo · Primer Aniversario</p>

            <h1 class="lrs-hero__title">
              <span class="lrs-hero__title-line lrs-hero__title-line--sm">El 1er Social de</span>
              <span class="lrs-hero__title-line lrs-hero__title-line--lg lrs-neon-blue">Salsa y</span>
              <span class="lrs-hero__title-line lrs-hero__title-line--lg lrs-neon-blue">Bachata</span>
              <span class="lrs-hero__title-line lrs-hero__title-line--md">en Rengo</span>
            </h1>

            <p class="lrs-hero__tagline">
              Celebrando el primer aniversario de Latin Rengo.
            </p>

            <ul class="lrs-chips" aria-label="Datos del evento">
              <li class="lrs-chip">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <span>Fecha por confirmar</span>
              </li>
              <li class="lrs-chip">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>21:00 – 03:00 hrs</span>
              </li>
              <li class="lrs-chip">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span>Rengo, Chile</span>
              </li>
            </ul>

            <div class="lrs-hero__actions">
              <a class="lrs-btn lrs-btn--primary lrs-btn--wa" href={WA_TICKET} target="_blank" rel="noopener noreferrer">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                Reservar Entrada
              </a>
              <a class="lrs-btn lrs-btn--ghost" href="#programa">
                Ver programa
              </a>
            </div>
          </div>

          <div class="lrs-hero__poster" aria-hidden="true">
            <div class="lrs-hero__poster-frame">
              <img
                src="/images/latin-rengo-social-poster.jpg"
                alt="Afiche oficial Social de Rengo"
                width="380"
                height="536"
                loading="eager"
                fetchpriority="high"
              />
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ────────────────────────────────────────────
         ¿QUÉ ES UN SOCIAL?
         ──────────────────────────────────────────── -->
    <section class="lrs-section lrs-section--dark" aria-labelledby="que-es-heading">
      <div class="lrs-container lrs-container--narrow">
        <div class="lrs-section-header">
          <span class="lrs-eyebrow">Antes de llegar</span>
          <h2 class="lrs-heading" id="que-es-heading">¿Qué es un Social?</h2>
        </div>
        <div class="lrs-explainer">
          <p class="lrs-explainer__text">
            Un <strong>Social</strong> es una noche de baile libre donde cualquier persona puede llegar, bailar con quien quiera y disfrutar la música latina.
          </p>
          <p class="lrs-explainer__text">
            No hay coreografía que aprender. No hay pareja fija. No hay nivel mínimo. Solo baile, música y comunidad.
          </p>
          <p class="lrs-explainer__text">
            Si es tu primera vez, mejor. Llegas a la clase de las 21:00 y en una hora ya sabes cómo moverte en la pista.
          </p>
        </div>
      </div>
    </section>

    <!-- ────────────────────────────────────────────
         ¿POR QUÉ ASISTIR?
         ──────────────────────────────────────────── -->
    <section class="lrs-section lrs-section--darkest" aria-labelledby="por-que-heading">
      <div class="lrs-container">
        <div class="lrs-section-header">
          <span class="lrs-eyebrow">Razones para ir</span>
          <h2 class="lrs-heading" id="por-que-heading">¿Por qué asistir?</h2>
        </div>
        <ul class="lrs-why" aria-label="Razones para asistir al Social de Rengo">
          {WHY.map((item) => (
            <li class="lrs-why__item">
              <span class="lrs-why__icon" aria-hidden="true">{item.icon}</span>
              <span class="lrs-why__text">{item.text}</span>
            </li>
          ))}
        </ul>
        <div class="lrs-why__cta">
          <a class="lrs-btn lrs-btn--primary" href={WA_TICKET} target="_blank" rel="noopener noreferrer">
            Reservar entrada ahora
          </a>
        </div>
      </div>
    </section>

    <!-- ────────────────────────────────────────────
         ENTRADAS
         ──────────────────────────────────────────── -->
    <section class="lrs-section lrs-section--dark" id="entradas" aria-labelledby="entradas-heading">
      <div class="lrs-container">
        <div class="lrs-section-header">
          <span class="lrs-eyebrow">Entradas</span>
          <h2 class="lrs-heading" id="entradas-heading">Elige tu entrada</h2>
          <p class="lrs-lead">La preventa tiene cupo limitado. Reserva por WhatsApp para asegurar el mejor precio.</p>
        </div>

        <ul class="lrs-tickets">
          {TICKETS.map((t) => (
            <li class:list={["lrs-ticket", t.featured && "lrs-ticket--featured", `lrs-ticket--${t.color}`]}>
              {t.badge && (
                <span class:list={["lrs-ticket__badge", `lrs-ticket__badge--${t.color}`]}>
                  {t.badge}
                </span>
              )}
              <h3 class="lrs-ticket__name">{t.name}</h3>
              <div class="lrs-ticket__price">{t.price}</div>
              <p class="lrs-ticket__note">{t.note}</p>
              <ul class="lrs-ticket__items">
                {t.items.map((item) => (
                  <li class="lrs-ticket__item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
              <a class="lrs-btn lrs-btn--ticket" href={WA_TICKET} target="_blank" rel="noopener noreferrer">
                Reservar por WhatsApp
              </a>
            </li>
          ))}
        </ul>

        <p class="lrs-footnote lrs-footnote--center">Las entradas se reservan por WhatsApp. Cupo limitado.</p>
      </div>
    </section>

    <!-- ────────────────────────────────────────────
         CRONOGRAMA
         ──────────────────────────────────────────── -->
    <section class="lrs-section lrs-section--darkest" id="programa" aria-labelledby="cronograma-heading">
      <div class="lrs-container lrs-container--narrow">
        <div class="lrs-section-header">
          <span class="lrs-eyebrow">La noche</span>
          <h2 class="lrs-heading" id="cronograma-heading">Cronograma</h2>
        </div>

        <ol class="lrs-timeline" aria-label="Programa de la noche">
          {SCHEDULE.map((item) => (
            <li class:list={["lrs-timeline__item", item.marked && "lrs-timeline__item--marked"]}>
              <div class="lrs-timeline__time">{item.time}</div>
              <div class="lrs-timeline__body">
                <h3 class="lrs-timeline__title">{item.title}</h3>
                {item.desc && <p class="lrs-timeline__desc">{item.desc}</p>}
              </div>
            </li>
          ))}
        </ol>

        <p class="lrs-footnote lrs-footnote--center">* Horarios referenciales, sujetos a cambios.</p>
      </div>
    </section>

    <!-- ────────────────────────────────────────────
         GALERÍA
         ──────────────────────────────────────────── -->
    <section class="lrs-section lrs-section--dark" aria-labelledby="galeria-heading">
      <div class="lrs-container">
        <div class="lrs-section-header">
          <span class="lrs-eyebrow">Comunidad</span>
          <h2 class="lrs-heading" id="galeria-heading">Así es Latin Rengo</h2>
          <p class="lrs-lead">Clases, sociales y comunidad de salsa y bachata en Rengo.</p>
        </div>

        <div class="lrs-gallery" aria-label="Fotografías de clases y eventos de Latin Rengo">
          <div class="lrs-gallery__item lrs-gallery__item--tall">
            <div class="lrs-gallery__ph">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              <span>Clases de Latin Rengo</span>
            </div>
          </div>
          <div class="lrs-gallery__item">
            <div class="lrs-gallery__ph">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              <span>Baile social</span>
            </div>
          </div>
          <div class="lrs-gallery__item">
            <div class="lrs-gallery__ph">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              <span>Comunidad</span>
            </div>
          </div>
          <div class="lrs-gallery__item lrs-gallery__item--wide">
            <div class="lrs-gallery__ph">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              <span>Eventos anteriores</span>
            </div>
          </div>
          <div class="lrs-gallery__item">
            <div class="lrs-gallery__ph">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              <span>Presentaciones</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ────────────────────────────────────────────
         SHOWS / PRESENTACIONES
         ──────────────────────────────────────────── -->
    <section class="lrs-section lrs-section--darkest" aria-labelledby="shows-heading">
      <div class="lrs-container">
        <div class="lrs-section-header">
          <span class="lrs-eyebrow">En escena</span>
          <h2 class="lrs-heading" id="shows-heading">Shows de la noche</h2>
          <p class="lrs-lead">Los shows y academias invitados se confirmarán próximamente. Sigue a Latin Rengo en redes para saberlo primero.</p>
        </div>

        <div class="lrs-performers">
          {PERFORMERS.map((p) => (
            <div class:list={["lrs-performer", `lrs-performer--${p.color}`]}>
              <div class="lrs-performer__ring" aria-hidden="true">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </div>
              <p class="lrs-performer__name">{p.label}</p>
              <p class="lrs-performer__role">{p.role}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ────────────────────────────────────────────
         NACE SOCIAL DE RENGO
         ──────────────────────────────────────────── -->
    <section class="lrs-section lrs-nace-section" aria-labelledby="nace-heading">
      <div class="lrs-nace-bg" aria-hidden="true">
        <div class="lrs-nace-glow lrs-nace-glow--left"></div>
        <div class="lrs-nace-glow lrs-nace-glow--right"></div>
      </div>
      <div class="lrs-container lrs-container--narrow">
        <span class="lrs-eyebrow">Latin Rengo</span>
        <h2 class="lrs-nace__title" id="nace-heading">
          Nace el<br>
          <em class="lrs-neon-blue">Social de Rengo</em>
        </h2>
        <p class="lrs-nace__text">
          Este no es solo un evento de aniversario. Es el comienzo de algo que Rengo no tenía: un espacio propio para la salsa y la bachata.
        </p>
        <p class="lrs-nace__text">
          Latin Rengo cumple un año construyendo comunidad en la región. El Social de Rengo nace para ser un punto de encuentro mensual, donde la gente pueda bailar, conocerse y crecer junto a la música latina.
        </p>
        <p class="lrs-nace__text lrs-nace__text--accent">
          Si vienes, eres parte del comienzo.
        </p>
      </div>
    </section>

    <!-- ────────────────────────────────────────────
         FAQ
         ──────────────────────────────────────────── -->
    <section class="lrs-section lrs-section--dark" id="preguntas" aria-labelledby="faq-heading">
      <div class="lrs-container lrs-container--narrow">
        <div class="lrs-section-header">
          <span class="lrs-eyebrow">Dudas frecuentes</span>
          <h2 class="lrs-heading" id="faq-heading">Preguntas frecuentes</h2>
        </div>

        <div class="lrs-faq">
          {FAQS.map((item) => (
            <details class="lrs-faq__item">
              <summary class="lrs-faq__question">
                <span>{item.q}</span>
                <span class="lrs-faq__icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </summary>
              <p class="lrs-faq__answer">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ────────────────────────────────────────────
         CTA FINAL
         ──────────────────────────────────────────── -->
    <section class="lrs-cta-section" aria-labelledby="cta-heading">
      <div class="lrs-cta-bg" aria-hidden="true">
        <div class="lrs-cta-glow lrs-cta-glow--left"></div>
        <div class="lrs-cta-glow lrs-cta-glow--right"></div>
      </div>
      <div class="lrs-container lrs-container--narrow">
        <h2 class="lrs-cta__title" id="cta-heading">
          Rengo tendrá su primer<br>
          <em class="lrs-neon-blue">Social de Salsa<br>y Bachata.</em>
        </h2>
        <p class="lrs-cta__desc">
          Queremos que seas parte del comienzo.
        </p>
        <a class="lrs-btn lrs-btn--primary lrs-btn--lg lrs-btn--wa" href={WA_TICKET} target="_blank" rel="noopener noreferrer">
