---
import DossierCard from '../../components/DossierCard.astro';
import FeaturedVideoBlock from '../../components/FeaturedVideoBlock.astro';
import PageHero from '../../components/PageHero.astro';
import { SITE_CONTACT, YOUTUBE_CHANNEL_URL } from '../../data/site';
import { dossiers } from '../../data/dossiers';
import { videos } from '../../data/videos';
import MainLayout from '../../layouts/MainLayout.astro';

const videoCompania = videos.find((v) => v.id === 'show-variete-circo');
const videoObra = videos.find((v) => v.id === 'la-tarea-mas-dificil-funcion');
---

<MainLayout
	title="Presentaciones | Espacio Elementos"
	description="Presentaciones y formatos escenicos para eventos, celebraciones, instituciones y programacion cultural."
	image="/images/servicios/presentaciones.jpg"
>
	<PageHero
		eyebrow="Presentaciones"
		title="Formatos escenicos para eventos, celebraciones y programacion"
		description="Espacio Elementos desarrolla presentaciones y experiencias en vivo que cruzan movimiento, artes escenicas y presencia corporal para distintos tipos de publico."
		image="/images/servicios/presentaciones.jpg"
		imageAlt="Presentaciones de Espacio Elementos"
		actions={[
			{ label: 'Conversemos tu evento', href: SITE_CONTACT.whatsappHref, target: '_blank' },
			{ label: 'Escribir por correo', href: SITE_CONTACT.emailHref, variant: 'secondary' },
		]}
	/>

	<section class="page-section page-section--wash-gold page-section--symbol-fire">
		<div class="container split-panel">
			<div>
				<p class="eyebrow">Aplicaciones</p>
				<h2>Una propuesta pensada para contextos reales</h2>
				<ul class="check-list">
					<li>Eventos privados y celebraciones</li>
					<li>Actividades de colegios y organizaciones</li>
					<li>Instancias municipales o comunitarias</li>
					<li>Encuentros con componente artistico o experiencial</li>
				</ul>
			</div>
			<div class="trust-panel">
				<h3>Que puedes esperar</h3>
				<ul class="check-list">
					<li>Propuesta con identidad, no generica</li>
					<li>Trato cercano con contraparte clara</li>
					<li>Posibilidad de articular presentacion y experiencia</li>
					<li>Material comercial disponible a solicitud</li>
				</ul>
			</div>
		</div>
	</section>

	<section class="page-section page-section--wash-blue page-section--symbol-water">
		<div class="container">
			<div class="section-heading">
				<p class="eyebrow">Registro en video</p>
				<h2>La propuesta en accion</h2>
			</div>
			{/* PENDIENTE: Video de show/varieté de circo — Álvaro elige desde videos.ts (id: 'show-variete-circo').
			    Elegir desde playlist "Varietés de circo". Registro de presentacion en escena con malabares,
			    tela aerea, acrobacia grupal o zancos.
			    Registro de presentacion de Compania Elementos — pendiente de seleccion y entrega por Álvaro. */}
			<FeaturedVideoBlock
				eyebrow="Compania Elementos en escena"
				title={videoCompania?.isPending
					? 'Registro de show pendiente de seleccion'
					: (videoCompania?.title ?? 'Show de Compania Elementos')}
				description={videoCompania?.isPending
					? 'Video pendiente de seleccion por Alvaro. Se elegira desde la playlist de Varietes de circo: malabares, tela aerea, acrobacia grupal o zancos en escena.'
					: (videoCompania?.description ?? '')}
				thumbnail={videoCompania?.thumbnail || undefined}
				videoUrl={videoCompania?.videoUrl || YOUTUBE_CHANNEL_URL}
				ctaLabel={videoCompania?.isPending ? 'Ver canal mientras se confirma' : 'Ver video'}
				secondaryCta={{ label: 'Cotizar show', href: SITE_CONTACT.whatsappHref, target: '_blank' }}
			/>
		</div>
	</section>

	<section class="page-section page-section--wash-green page-section--symbol-earth">
		<div class="container">
			<div class="section-heading">
				<p class="eyebrow">La Tarea Mas Dificil</p>
				<h2>La obra en accion</h2>
			</div>
			{/* PENDIENTE: Video de La Tarea Más Difícil — Álvaro elige desde videos.ts (id: 'la-tarea-mas-dificil-funcion').
			    Elegir desde playlist "Funciones de La Tarea Más Difícil".
			    Registro de funcion de La Tarea Mas Dificil — pendiente de seleccion y entrega por Álvaro. */}
			<FeaturedVideoBlock
				eyebrow="Circo contemporaneo"
				title={videoObra?.isPending
					? 'Registro de La Tarea Mas Dificil — pendiente'
					: (videoObra?.title ?? 'La Tarea Mas Dificil')}
				description={videoObra?.isPending
					? 'Video pendiente de seleccion por Alvaro. Se elegira desde la playlist de Funciones de La Tarea Mas Dificil.'
					: (videoObra?.description ?? '')}
				thumbnail={videoObra?.thumbnail || undefined}
				videoUrl={videoObra?.videoUrl || YOUTUBE_CHANNEL_URL}
				ctaLabel={videoObra?.isPending ? 'Ver canal mientras se confirma' : 'Ver video'}
				secondaryCta={{ label: 'Solicitar ficha tecnica', href: SITE_CONTACT.emailHref }}
			/>
		</div>
	</section>

	<section class="page-section page-section--wash-orange page-section--symbol-fire">
		<div class="container">
			<div class="section-heading">
				<p class="eyebrow">Dossier</p>
				<h2>Presentaciones con material comercial listo para compartir</h2>
			</div>
			<DossierCard dossier={dossiers[1]} />
		</div>
	</section>
</MainLayout>
