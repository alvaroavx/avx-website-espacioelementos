---
const destination = '/latin-rengo-social';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<meta http-equiv="refresh" content={`0; url=${destination}`} />
		<link rel="canonical" href={destination} />
		<title>Redirigiendo a Latin Rengo Social</title>
		<script is:inline>
			window.location.replace('/latin-rengo-social');
		</script>
	</head>
	<body>
		<p>Redirigiendo a <a href={destination}>Latin Rengo Social</a>.</p>
	</body>
</html>
