---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import {
  latinRengoEvent,
  eventFacts,
  tickets,
  ticketIncludes,
  reasonsToAttend,
  eventAmenities,
  faqs,
} from '../data/latin-rengo';

/* ---------- Schedule for v3 (brief spec: includes 22:15 entry) ---------- */
const SCHEDULE = [
  { time: "21:00", title: "Clase inicial de Salsa Cubana",   desc: "Para todos los niveles. Sin experiencia previa.",        accent: false },
  { time: "22:00", title: "Bienvenida oficial",              desc: "Apertura del 1er Social de Salsa y Bachata de Rengo.", accent: true  },
  { time: "22:15", title: "Presentaciones invitadas",        desc: "Academias y artistas invitados toman la pista.",        accent: false },
  { time: "23:00", title: "Social Latino",                   desc: "Pista libre. Salsa, bachata y más.",                    accent: false },
  { time: "03:00", title: "Cierre",                         desc: "",                                                       accent: false },
];
---

<!doctype html>
<html lang="es">
<head>
  <BaseHead
    title={latinRengoEvent.seo.title}
    description={latinRengoEvent.seo.description}
    image={latinRengoEvent.seo.image}
  />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>

<body class="page page--latin-rengo-v3">

  <Header />

  <main class="site-main v3-main" id="v3-top">

    <!-- ══════════════════════════════════════════
         HERO
         ══════════════════════════════════════════ -->
    <section class="v3-hero" aria-labelledby="v3-hero-title">
      <div class="v3-hero__bg" aria-hidden="true">
        <div class="v3-glow v3-glow--a"></div>
        <div class="v3-glow v3-glow--b"></div>
        <div class="v3-glow v3-glow--c"></div>
      </div>

      <div class="v3-shell">
        <div class="v3-hero__layout">

          <div class="v3-hero__body">
            <p class="v3-kicker">
              <span class="v3-kicker__dot" aria-hidden="true"></span>
              Latin Rengo · Primer Aniversario
            </p>

            <h1 class="v3-hero__title" id="v3-hero-title">
              <span class="v3-hero__title-sub">El 1er Social de</span>
              <span class="v3-hero__title-main v3-neon-blue">Salsa y<br>Bachata</span>
              <span class="v3-hero__title-loc">en Rengo</span>
            </h1>

            <p class="v3-hero__tagline">{latinRengoEvent.message}</p>

            <ul class="v3-chips" aria-label="Datos del evento">
              <li class="v3-chip">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <time datetime={latinRengoEvent.dateTime}>{latinRengoEvent.date}</time>
              </li>
              <li class="v3-chip">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>{latinRengoEvent.startTime} – {latinRengoEvent.endTime}</span>
              </li>
              <li class="v3-chip">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span>{latinRengoEvent.venue}</span>
              </li>
              <li class="v3-chip v3-chip--accent">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M2 20h.01M7 20v-4M12 20V10M17 20V4M22 20h.01"/></svg>
                <span>Desde $3.000</span>
              </li>
            </ul>

            <div class="v3-hero__actions">
              <a class="v3-btn v3-btn--wa" href={latinRengoEvent.whatsappHref} target="_blank" rel="noopener noreferrer">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                Reservar entrada
              </a>
              <a class="v3-btn v3-btn--ghost" href="#cronograma">Ver programa</a>
            </div>
          </div>

          <aside class="v3-hero__poster" aria-hidden="true">
            <div class="v3-hero__poster-frame">
              <img
                src="/images/latin-rengo-social-poster.jpg"
                alt="Afiche oficial Latin Rengo Social"
                width="380"
                height="536"
                loading="eager"
                fetchpriority="high"
              />
            </div>
          </aside>

        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         FACTS STRIP
         ══════════════════════════════════════════ -->
    <div class="v3-facts-strip" role="region" aria-label="Información rápida del evento">
      <div class="v3-shell">
        <dl class="v3-facts">
          {eventFacts.map((fact, i) => (
            <>
              {i > 0 && <div class="v3-fact-div" aria-hidden="true"></div>}
              <div class="v3-fact">
                <dt>{fact.label}</dt>
                <dd class:list={[fact.label === 'Entradas' && 'v3-fact__dd--accent']}>{fact.value}</dd>
              </div>
            </>
          ))}
        </dl>
      </div>
    </div>

    <!-- ══════════════════════════════════════════
         ¿QUÉ ES UN SOCIAL?
         ══════════════════════════════════════════ -->
    <section class="v3-section v3-section--2" aria-labelledby="v3-que-es">
      <div class="v3-shell v3-two-col">
        <header>
          <p class="v3-eyebrow">Antes de llegar</p>
          <h2 class="v3-heading" id="v3-que-es">¿Qué es un social?</h2>
        </header>
        <div class="v3-prose">
          <p>Un social es un espacio para bailar, compartir y conocer personas a través de la salsa y la bachata. No es una competencia y no necesitas asistir con pareja.</p>
          <p>Tampoco necesitas experiencia previa. La noche comienza con una clase de Salsa Cubana para que quienes recién parten puedan aprender pasos básicos y entrar en ambiente.</p>
          <p>Después de los shows invitados, la pista queda abierta para bailar, cambiar de pareja, conversar y disfrutar la música en comunidad.</p>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         NACE SOCIAL DE RENGO
         ══════════════════════════════════════════ -->
    <section class="v3-section v3-section--brand" aria-labelledby="v3-nace">
      <div class="v3-shell v3-two-col">
        <header>
          <p class="v3-eyebrow">Latin Rengo · 1er aniversario</p>
          <h2 class="v3-heading" id="v3-nace">Nace Social de Rengo</h2>
        </header>
        <div class="v3-prose">
          <p>Este evento marca el inicio de una iniciativa permanente para reunir a la comunidad salsera y bachatera de Rengo y sus alrededores.</p>
          <p>Hace un año comenzamos con unas pocas personas que querían aprender a bailar. Hoy celebramos creando el primer Social de Salsa y Bachata de Rengo.</p>
          <p class="v3-prose__accent">Gracias por ser parte de esta historia.</p>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         ¿POR QUÉ ASISTIR?
         ══════════════════════════════════════════ -->
    <section class="v3-section v3-section--3" aria-labelledby="v3-por-que">
      <div class="v3-shell">
        <header class="v3-section-head">
          <p class="v3-eyebrow">Razones para ir</p>
          <h2 class="v3-heading" id="v3-por-que">¿Por qué asistir?</h2>
        </header>
        <ul class="v3-why" aria-label="Razones para asistir">
          {reasonsToAttend.map((r) => (
            <li class="v3-why__item">
              <span class="v3-why__check" aria-hidden="true">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span>{r}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         QUÉ INCLUYE
         ══════════════════════════════════════════ -->
    <section class="v3-section v3-section--2" aria-labelledby="v3-incluye">
      <div class="v3-shell v3-two-col">
        <header>
          <p class="v3-eyebrow">Tu entrada</p>
          <h2 class="v3-heading" id="v3-incluye">¿Qué incluye?</h2>
        </header>
        <ul class="v3-includes">
          {ticketIncludes.map((item) => (
            <li class="v3-includes__item">
              <span class="v3-includes__icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         ENTRADAS
         ══════════════════════════════════════════ -->
    <section id="entradas" class="v3-section v3-section--1" aria-labelledby="v3-entradas">
      <div class="v3-shell">
        <header class="v3-section-head">
          <p class="v3-eyebrow">Valores</p>
          <h2 class="v3-heading" id="v3-entradas">Entradas</h2>
          <p class="v3-section-lead">Reserva por WhatsApp para asegurar tu lugar. El valor en puerta está sujeto a disponibilidad.</p>
        </header>

        <ul class="v3-tickets" aria-label="Opciones de entrada">
          {tickets.map((t, i) => (
            <li class:list={["v3-ticket", i === 1 && "v3-ticket--featured"]}>
              {i === 0 && <span class="v3-ticket__tag v3-ticket__tag--orange">Mejor precio</span>}
              {i === 1 && <span class="v3-ticket__tag v3-ticket__tag--blue">Más elegida</span>}
              <h3 class="v3-ticket__name">{t.name}</h3>
              <div class="v3-ticket__price">{t.price}</div>
              {t.note && <p class="v3-ticket__note">{t.note}</p>}
              <a class="v3-btn v3-btn--ticket" href={latinRengoEvent.whatsappHref} target="_blank" rel="noopener noreferrer">
                Reservar por WhatsApp
              </a>
            </li>
          ))}
        </ul>

        <p class="v3-footnote">
          Todas las entradas incluyen clase de Salsa Cubana + ingreso al social.<br>
          El cupo de preventa es limitado.
        </p>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CRONOGRAMA
         ══════════════════════════════════════════ -->
    <section id="cronograma" class="v3-section v3-section--3" aria-labelledby="v3-cronograma">
      <div class="v3-shell v3-two-col">
        <header>
          <p class="v3-eyebrow">Programa</p>
          <h2 class="v3-heading" id="v3-cronograma">Cronograma</h2>
          <p class="v3-section-lead--sm">Los horarios pueden ajustarse levemente.</p>
        </header>
        <ol class="v3-timeline" aria-label="Programa de la noche">
          {SCHEDULE.map((item) => (
            <li class:list={["v3-timeline__item", item.accent && "v3-timeline__item--accent"]}>
              <time class="v3-timeline__time">{item.time}</time>
              <div class="v3-timeline__body">
                <strong class="v3-timeline__title">{item.title}</strong>
                {item.desc && <p class="v3-timeline__desc">{item.desc}</p>}
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         PRESENTACIONES
         ══════════════════════════════════════════ -->
    <section class="v3-section v3-section--2" aria-labelledby="v3-presentaciones">
      <div class="v3-shell">
        <header class="v3-section-head">
          <p class="v3-eyebrow">Invitados</p>
          <h2 class="v3-heading" id="v3-presentaciones">Presentaciones</h2>
        </header>
        <div class="v3-performers-ph">
          <p class="v3-performers-ph__msg">
            Pronto anunciaremos las academias, artistas y bailarines invitados.
          </p>
          <div class="v3-performers-ph__slots" aria-hidden="true">
            {["Academia invitada", "Artista invitado", "Show invitado"].map((label) => (
              <div class="v3-performers-ph__slot">
                <div class="v3-performers-ph__icon">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                </div>
                <span>{label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         HABRÁ
         ══════════════════════════════════════════ -->
    <section class="v3-section v3-section--1" aria-labelledby="v3-habra">
      <div class="v3-shell">
        <header class="v3-section-head">
          <p class="v3-eyebrow">Durante el evento</p>
          <h2 class="v3-heading" id="v3-habra">Habrá</h2>
        </header>
        <ul class="v3-amenities" aria-label="Servicios disponibles en el evento">
          {eventAmenities.map((a) => (
            <li class="v3-amenity">
              <h3 class="v3-amenity__title">{a.title}</h3>
              <p class="v3-amenity__detail">{a.detail}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         UBICACIÓN
         ══════════════════════════════════════════ -->
    <section id="ubicacion" class="v3-section v3-section--3" aria-labelledby="v3-ubicacion">
      <div class="v3-shell">
        <header class="v3-section-head">
          <p class="v3-eyebrow">Cómo llegar</p>
          <h2 class="v3-heading" id="v3-ubicacion">Ubicación</h2>
        </header>
        <div class="v3-location">
          <div class="v3-location__info">
            <h3 class="v3-location__venue">{latinRengoEvent.venue}</h3>
            <p class="v3-location__city">Rengo, Región de O'Higgins, Chile</p>
            <dl class="v3-location__details">
              <div>
                <dt>Dirección exacta</dt>
                <dd>{latinRengoEvent.address}</dd>
              </div>
              <div>
                <dt>Referencias</dt>
                <dd>Disponibles al reservar tu entrada</dd>
              </div>
              <div>
                <dt>Estacionamiento</dt>
                <dd>Consulta disponibilidad al reservar</dd>
              </div>
            </dl>
          </div>
          <div class="v3-location__map" aria-label="Solicitar ubicación exacta por WhatsApp">
            <div class="v3-location__map-inner">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <p>¿Necesitas la dirección exacta?</p>
              <a class="v3-btn v3-btn--ghost-sm" href={latinRengoEvent.whatsappHref} target="_blank" rel="noopener noreferrer">
                Pedir por WhatsApp
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         FAQ
         ══════════════════════════════════════════ -->
    <section id="preguntas" class="v3-section v3-section--2" aria-labelledby="v3-faq">
      <div class="v3-shell v3-shell--narrow">
        <header class="v3-section-head">
          <p class="v3-eyebrow">Antes de asistir</p>
          <h2 class="v3-heading" id="v3-faq">Preguntas frecuentes</h2>
        </header>
        <div class="v3-faq">
          {faqs.map((item) => (
            <details class="v3-faq__item">
              <summary class="v3-faq__q">
                <span>{item.question}</span>
                <span class="v3-faq__icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </summary>
              <p class="v3-faq__a">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CTA FINAL
         ══════════════════════════════════════════ -->
    <section class="v3-cta" aria-labelledby="v3-cta-title">
      <div class="v3-cta__bg" aria-hidden="true">
        <div class="v3-cta__glow v3-cta__glow--a"></div>
        <div class="v3-cta__glow v3-cta__glow--b"></div>
      </div>
      <div class="v3-shell v3-shell--narrow">
        <p class="v3-eyebrow">Nuestra historia continúa</p>
        <h2 class="v3-cta__title" id="v3-cta-title">
          El comienzo de<br>
          <em class="v3-neon-blue">Social de Rengo</em>
        </h2>
        <p class="v3-cta__desc">
          Rengo tendrá su primer Social de Salsa y Bachata.<br>
          Queremos que seas parte del comienzo.
        </p>
        <a class="v3-btn v3-btn--wa v3-btn--lg" href={latinRengoEvent.whatsappHref} target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
          Comprar entrada por WhatsApp
        </a>
        <p class="v3-cta__contact">
          {latinRengoEvent.contactLabel} · <a href="/" class="v3-link">Espacio Elementos</a>
        </p>
      </div>
    </section>

  </main>

  <Footer />

  <!-- Flotante WhatsApp -->
  <a
    class="v3-wa-float"
    href={latinRengoEvent.whatsappHref}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Reservar entrada por WhatsApp"
  >
    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
