---
import Hero from './Hero.astro';

interface Action {
	label: string;
	href: string;
	variant?: 'primary' | 'secondary';
	target?: string;
}

interface Props {
	eyebrow?: string;
	title: string;
	description: string;
	image?: string;
	imageAlt?: string;
	actions?: Action[];
	compact?: boolean;
	carouselId?: string;
	autoplay?: boolean;
	interval?: number;
	slides?: Array<{
		eyebrow?: string;
		title: string;
		description: string;
		image: string;
		imageAlt?: string;
		actions?: Action[];
	}>;
}

const {
	eyebrow,
	title,
	description,
	image,
	imageAlt = '',
	actions = [],
	compact = false,
	slides = [],
} = Astro.props;
---

<Hero
	eyebrow={eyebrow}
	title={title}
	description={description}
	image={image}
	imageAlt={imageAlt}
	actions={actions}
	compact={compact}
	slides={slides}
/>
