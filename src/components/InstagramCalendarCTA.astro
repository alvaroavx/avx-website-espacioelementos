---
interface Props {
	title: string;
	description?: string;
	instagramUrl: string;
	ctaLabel: string;
}

const {
	title,
	description = 'El calendario mensual, cambios de horario y novedades se actualizan primero en Instagram.',
	instagramUrl,
	ctaLabel,
} = Astro.props;
---

<section class="instagram-calendar-cta">
	<div>
		<p class="eyebrow">Instagram</p>
		<h2>{title}</h2>
		<p>{description}</p>
	</div>
	<a class="site-button" href={instagramUrl} target="_blank" rel="noopener noreferrer">{ctaLabel}</a>
</section>
