---
import ServiceDetailCard from './ServiceDetailCard.astro';
import type { ServiceItem } from '../data/services';

interface Props {
	service: ServiceItem;
}

const { service } = Astro.props;
---

<ServiceDetailCard
	title={service.title}
	category="Servicio"
	description={service.summary}
	audiences={service.audiences.slice(0, 3)}
	includes={service.highlights.slice(0, 2)}
	formats={service.formats.slice(0, 3)}
	ctaLabel="Ver detalle"
	ctaHref={service.href}
	secondaryCtaLabel={service.contactLabel}
	secondaryCtaHref={service.contactHref}
	dossier={service.dossierHref ? { href: service.dossierHref } : undefined}
	image={service.image}
	imageAlt={service.imageAlt}
	compact
/>
