---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
import { NAV_ITEMS, SITE_CONTACT, SOCIAL_LINKS } from '../data/site';
---

<header class="site-header">
	<nav class="site-header__nav-wrap" aria-label="Navegacion principal">
		<div class="container site-header__inner">
			<a class="site-header__brand" href="/" aria-label={SITE_TITLE}>
				<img src="/images/logo-espacio-elementos.png" alt={SITE_TITLE} width="270" height="77" decoding="async" />
			</a>

			<div class="site-header__menu">
				<input class="site-header__checkbox" type="checkbox" id="siteNavToggle" aria-label="Abrir navegacion" />
				<label class="site-header__toggle" for="siteNavToggle" aria-hidden="true">
					<span></span>
					<span></span>
					<span></span>
				</label>

				<div class="site-header__panel">
					<ul class="site-header__nav">
						{NAV_ITEMS.map((item) => (
							<li>
								<HeaderLink href={item.href} class="site-header__link">
									{item.label}
								</HeaderLink>
							</li>
						))}
						<li class="site-header__cta-wrap">
							<a class="site-button site-button--small" href={SITE_CONTACT.whatsappHref} target="_blank" rel="noopener noreferrer">
								Cotiza por WhatsApp
							</a>
						</li>
					</ul>
					<div class="site-header__social">
						{SOCIAL_LINKS.map((link) => (
							<a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label}>
								<img src={link.icon} alt="" width="34" height="34" loading="lazy" decoding="async" />
							</a>
						))}
					</div>
				</div>
			</div>
		</div>
	</nav>
</header>
