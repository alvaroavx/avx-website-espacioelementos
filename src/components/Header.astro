---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
import { NAV_ITEMS, SITE_CONTACT, SOCIAL_LINKS } from '../data/site';
---

<header class="site-header">
  <nav class="navbar navbar-expand-lg">
    <div class="container site-header__inner">
      <a class="navbar-brand site-header__brand" href="/" aria-label={SITE_TITLE}>
        <img src="/images/logo-espacio-elementos.png" alt={SITE_TITLE} width="270" />
      </a>

      <button
        class="navbar-toggler site-header__toggle"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#siteNav"
        aria-controls="siteNav"
        aria-expanded="false"
        aria-label="Abrir navegacion"
      >
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="siteNav">
        <ul class="navbar-nav ms-auto align-items-lg-center site-header__nav">
          {NAV_ITEMS.map((item) => (
            <li class="nav-item">
              <HeaderLink href={item.href} class="nav-link site-header__link">
                {item.label}
              </HeaderLink>
            </li>
          ))}
          <li class="nav-item site-header__cta-wrap">
            <a class="site-button site-button--small" href={SITE_CONTACT.whatsappHref} target="_blank" rel="noopener noreferrer">
              Cotiza por WhatsApp
            </a>
          </li>
        </ul>
        <div class="site-header__social d-lg-none">
          {SOCIAL_LINKS.map((link) => (
            <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label}>
              <img src={link.icon} alt={link.label} width="34" height="34" />
            </a>
          ))}
        </div>
      </div>
    </div>
  </nav>
</header>
