---
interface Props {
	quote: string;
	name?: string;
	context?: string;
	image?: string;
	imageAlt?: string;
}

const { quote, name, context, image, imageAlt = '' } = Astro.props;
---

<figure class="quote-card">
	{image && <img src={image} alt={imageAlt} width="112" height="112" loading="lazy" decoding="async" />}
	<blockquote>
		<p>{quote}</p>
	</blockquote>
	{(name || context) && (
		<figcaption>
			{name && <strong>{name}</strong>}
			{context && <span>{context}</span>}
		</figcaption>
	)}
</figure>
