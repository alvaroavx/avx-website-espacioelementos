---
import { NAV_ITEMS, SITE_CONTACT, SOCIAL_LINKS } from '../data/site';

const today = new Date();
---

<footer class="site-footer">
	<div class="container site-footer__grid">
		<div>
			<img src="/images/elementos-blanco.png" alt="Elementos" width="92" height="92" loading="lazy" decoding="async" />
			<p class="site-footer__lead">
				Movimiento, artes escenicas, bienestar y comunidad con una mirada profesional, humana y territorial.
			</p>
		</div>

		<div>
			<h2 class="site-footer__title">Navegacion</h2>
			<ul class="site-footer__list">
				{NAV_ITEMS.map((item) => (
					<li><a href={item.href}>{item.label}</a></li>
				))}
			</ul>
		</div>

		<div>
			<h2 class="site-footer__title">Contacto</h2>
			<ul class="site-footer__list">
				<li><a href={SITE_CONTACT.emailHref}>{SITE_CONTACT.email}</a></li>
				<li><a href={SITE_CONTACT.whatsappHref} target="_blank" rel="noopener noreferrer">{SITE_CONTACT.whatsappLabel}</a></li>
				<li>{SITE_CONTACT.location}</li>
			</ul>
		</div>

		<div>
			<h2 class="site-footer__title">Redes</h2>
			<div class="site-footer__social">
				{SOCIAL_LINKS.map((link) => (
					<a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label}>
						<img src={link.icon} alt="" width="42" height="42" loading="lazy" decoding="async" />
					</a>
				))}
			</div>
		</div>
	</div>

	<div class="container site-footer__bottom">
		<p>&copy; Espacio Elementos {today.getFullYear()}</p>
		<p>
			Implementacion por <a href="https://avx.cl/" target="_blank" rel="noopener noreferrer">AVX Informatica</a>
		</p>
	</div>
</footer>
